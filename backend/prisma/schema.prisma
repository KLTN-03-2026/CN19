generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String                   @id @default(uuid())
  email                 String                   @unique
  phone_number          String?                  @unique
  password_hash         String
  role                  String
  status                String                   @default("active")
  wallet_address        String?
  avatar_url            String?
  address               String?
  date_of_birth         DateTime?
  failed_login_attempts Int                      @default(0)
  created_at            DateTime                 @default(now())
  full_name             String?
  wallet_private_key    String?
  latitude              Decimal?
  longitude             Decimal?
  permissions           String[]                 @default([])
  account_holder        String?
  account_number        String?
  balance               Decimal                  @default(0)
  bank_name             String?
  admin_logs            AdminActionLog[]
  authored_blogs        Blog[]                   @relation("BlogAuthor")
  blog_reports          BlogReport[]
  bot_logs              BotDetectionLog[]
  comments              Comment[]
  created_assignments   EventStaffAssignment[]   @relation("Creator")
  staff_assignments     EventStaffAssignment[]   @relation("StaffMember")
  likes                 Like[]
  listings              MarketplaceListing[]
  buyer_transactions    MarketplaceTransaction[] @relation("Buyer")
  seller_transactions   MarketplaceTransaction[] @relation("Seller")
  owned_products        MerchandiseOrderItem[]   @relation("ProductOwner")
  merchandise_scans     MerchandiseScanHistory[]
  notifications         Notification[]
  orders                Order[]
  organizer_profile     Organizer?
  refunds               RefundRequest[]
  ticket_scans          ScanHistory[]
  owned_tickets         Ticket[]                 @relation("CurrentOwner")
  original_tickets      Ticket[]                 @relation("OriginalBuyer")
  transfers_sent        TicketTransfer[]         @relation("Sender")
  transfers_received    TicketTransfer[]         @relation("Receiver")
  wallet_transactions   WalletTransaction[]
  withdrawal_requests   WithdrawalRequest[]
}

model Organizer {
  id                String        @id @default(uuid())
  user_id           String        @unique
  organization_name String
  kyc_status        String        @default("pending")
  kyc_verified_at   DateTime?
  business_license  String?
  identity_card     String?
  is_verified       Boolean       @default(false)
  description       String?
  address_raw       String?
  back_image_url    String?
  dob_raw           String?
  face_image_url    String?
  facematch_score   Float?
  front_image_url   String?
  full_name_raw     String?
  id_number         String?
  kyc_raw_data      Json?
  liveness_score    Float?
  events            Event[]
  merchandise       Merchandise[]
  user              User          @relation(fields: [user_id], references: [id])
}

model EventStaffAssignment {
  id          String @id @default(uuid())
  staff_id    String
  event_id    String
  creator_id  String
  assigned_by User   @relation("Creator", fields: [creator_id], references: [id])
  event       Event  @relation(fields: [event_id], references: [id])
  staff       User   @relation("StaffMember", fields: [staff_id], references: [id])
}

model Category {
  id         String   @id @default(uuid())
  name       String   @unique
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  image_url  String?
  events     Event[]
}

model Event {
  id                          String                 @id @default(uuid())
  organizer_id                String
  category_id                 String
  title                       String
  event_date                  DateTime
  event_time                  String?
  status                      String                 @default("draft")
  allow_resale                Boolean                @default(true)
  allow_transfer              Boolean                @default(true)
  allow_refund                Boolean                @default(true)
  price_ceiling               Decimal?
  royalty_fee_percent         Decimal                @default(3.0)
  smart_contract_address      String?
  refund_deadline_days        Int?
  description                 String?
  image_url                   String?
  end_date                    DateTime?
  end_time                    String?
  latitude                    Float?
  location_address            String?
  longitude                   Float?
  video_url                   String?
  created_at                  DateTime               @default(now())
  updated_at                  DateTime               @updatedAt
  seating_charts              String[]               @default([])
  resale_price_limit_percent  Decimal                @default(108.0)
  is_featured                 Boolean                @default(false)
  resale_gas_fee              Decimal                @default(10000.0)
  resale_platform_fee_percent Decimal                @default(3.0)
  commission_fee_percent      Decimal                @default(3.0)
  platform_fee_percent        Decimal                @default(5.0)
  blogs                       Blog[]
  emergency_requests          EmergencyRequest[]
  payouts                     EscrowPayout[]
  category                    Category               @relation(fields: [category_id], references: [id])
  organizer                   Organizer              @relation(fields: [organizer_id], references: [id])
  staff_assignments           EventStaffAssignment[]
  marketplace_listings        MarketplaceListing[]
  merchandise                 Merchandise[]
  orders                      Order[]
  tickets                     Ticket[]
  ticket_tiers                TicketTier[]
}

model EmergencyRequest {
  id            String    @id @default(uuid())
  event_id      String
  request_type  String
  reason        String
  new_date      DateTime?
  new_time      String?
  new_end_date  DateTime?
  new_end_time  String?
  status        String    @default("pending")
  admin_notes   String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  evidence_urls String[]  @default([])
  event         Event     @relation(fields: [event_id], references: [id])
}

model TicketTier {
  id                 String      @id @default(uuid())
  event_id           String
  tier_name          String
  section_name       String?
  benefits           String?
  price              Decimal
  quantity_total     Int
  quantity_available Int
  order_items        OrderItem[]
  tickets            Ticket[]
  event              Event       @relation(fields: [event_id], references: [id])
}

model Order {
  id                         String                 @id @default(uuid())
  customer_id                String
  event_id                   String
  order_number               String                 @unique
  status                     String
  subtotal                   Decimal
  platform_fee               Decimal                @default(0)
  total_amount               Decimal
  payment_method             String
  transaction_id             String?
  transaction_hash           String?
  risk_score                 Decimal?
  is_bot_detected            Boolean                @default(false)
  expires_at                 DateTime
  created_at                 DateTime               @default(now())
  is_settled                 Boolean                @default(false)
  metadata                   Json?
  order_type                 String                 @default("TICKET_PURCHASE")
  ip_address                 String?
  commission_fee             Decimal?               @default(0)
  gas_fee                    Decimal?               @default(0)
  organizer_revenue          Decimal?               @default(0)
  commission_fee_percent     Decimal?               @default(0)
  platform_fee_percent       Decimal?               @default(0)
  merchandise_commission_fee Decimal?               @default(0)
  merchandise_platform_fee   Decimal?               @default(0)
  ticket_commission_fee      Decimal?               @default(0)
  ticket_platform_fee        Decimal?               @default(0)
  bot_logs                   BotDetectionLog[]
  merchandise_items          MerchandiseOrderItem[]
  customer                   User                   @relation(fields: [customer_id], references: [id])
  event                      Event                  @relation(fields: [event_id], references: [id])
  items                      OrderItem[]
  payments                   Payment[]
  tickets                    Ticket[]
  transfers                  TicketTransfer[]
}

model Payment {
  id                      String                  @id @default(uuid())
  order_id                String?
  method                  String
  transaction_id          String?
  amount                  Decimal
  status                  String                  @default("pending")
  response_data           Json?
  paid_at                 DateTime                @default(now())
  created_at              DateTime                @default(now())
  updated_at              DateTime                @updatedAt
  mkt_transaction_id      String?
  marketplace_transaction MarketplaceTransaction? @relation(fields: [mkt_transaction_id], references: [id])
  order                   Order?                  @relation(fields: [order_id], references: [id])
}

model OrderItem {
  id             String     @id @default(uuid())
  order_id       String
  ticket_tier_id String
  quantity       Int
  unit_price     Decimal
  subtotal       Decimal
  order          Order      @relation(fields: [order_id], references: [id])
  ticket_tier    TicketTier @relation(fields: [ticket_tier_id], references: [id])
}

model Ticket {
  id                   String                   @id @default(uuid())
  order_id             String
  event_id             String
  ticket_tier_id       String
  ticket_number        String                   @unique
  nft_token_id         String?
  nft_mint_tx_hash     String?
  nft_token_uri        String?
  status               String
  current_owner_id     String
  original_buyer_id    String
  is_on_marketplace    Boolean                  @default(false)
  is_transferred       Boolean                  @default(false)
  is_used              Boolean                  @default(false)
  checked_in_at        DateTime?
  qr_code_hash         String?
  refund_requested_at  DateTime?
  transfer_count       Int                      @default(0)
  qr_tokens            DynamicQRToken[]
  marketplace_listings MarketplaceListing[]
  transactions         MarketplaceTransaction[]
  refund_requests      RefundRequest[]
  scan_history         ScanHistory[]
  current_owner        User                     @relation("CurrentOwner", fields: [current_owner_id], references: [id])
  event                Event                    @relation(fields: [event_id], references: [id])
  order                Order                    @relation(fields: [order_id], references: [id])
  original_buyer       User                     @relation("OriginalBuyer", fields: [original_buyer_id], references: [id])
  ticket_tier          TicketTier               @relation(fields: [ticket_tier_id], references: [id])
  transfers            TicketTransfer[]
}

model MarketplaceListing {
  id                   String                   @id @default(uuid())
  ticket_id            String
  seller_id            String
  event_id             String
  listing_number       String                   @unique
  asking_price         Decimal
  status               String
  is_locked            Boolean                  @default(false)
  lock_expires_at      DateTime?
  sold_at              DateTime?
  platform_fee_percent Decimal                  @default(5.0)
  metadata             Json?
  event                Event                    @relation(fields: [event_id], references: [id])
  seller               User                     @relation(fields: [seller_id], references: [id])
  ticket               Ticket                   @relation(fields: [ticket_id], references: [id])
  transactions         MarketplaceTransaction[]
  merchandise_items    MerchandiseOrderItem[]   @relation("ListingMerchandise")
}

model MarketplaceTransaction {
  id                        String             @id @default(uuid())
  listing_id                String
  ticket_id                 String
  seller_id                 String
  buyer_id                  String
  seller_receive_amount     Decimal
  platform_fee              Decimal
  buyer_pay_amount          Decimal
  status                    String
  nft_transfer_tx_hash      String?
  ip_address                String?
  created_at                DateTime           @default(now())
  commission_fee            Decimal?           @default(0)
  gas_fee                   Decimal?           @default(0)
  organizer_royalty         Decimal            @default(0)
  resale_profit             Decimal?           @default(0)
  is_settled                Boolean            @default(false)
  transaction_number        String?            @unique
  organizer_royalty_percent Decimal            @default(0)
  platform_fee_percent      Decimal            @default(0)
  buyer                     User               @relation("Buyer", fields: [buyer_id], references: [id])
  listing                   MarketplaceListing @relation(fields: [listing_id], references: [id])
  seller                    User               @relation("Seller", fields: [seller_id], references: [id])
  ticket                    Ticket             @relation(fields: [ticket_id], references: [id])
  payments                  Payment[]
}

model TicketTransfer {
  id                   String    @id @default(uuid())
  ticket_id            String
  from_user_id         String
  to_user_id           String
  event_id             String
  transfer_method      String
  status               String
  nft_transfer_tx_hash String?
  requested_at         DateTime  @default(now())
  completed_at         DateTime?
  order_id             String?
  sender               User      @relation("Sender", fields: [from_user_id], references: [id])
  order                Order?    @relation(fields: [order_id], references: [id])
  ticket               Ticket    @relation(fields: [ticket_id], references: [id])
  receiver             User      @relation("Receiver", fields: [to_user_id], references: [id])
}

model BotDetectionLog {
  id                 String   @id @default(uuid())
  user_id            String?
  order_id           String?
  click_speed_ms     Int      @default(0)
  form_fill_duration Int      @default(0)
  behavior_metrics   Json?
  risk_score         Decimal
  decision           String
  created_at         DateTime @default(now())
  detection_details  Json?
  ip_address         String?
  user_agent         String?
  event_type         String?
  order              Order?   @relation(fields: [order_id], references: [id])
  user               User?    @relation(fields: [user_id], references: [id])
}

model ScanHistory {
  id             String   @id @default(uuid())
  ticket_id      String
  is_success     Boolean
  failure_reason String?
  scanned_at     DateTime @default(now())
  staff_id       String?
  staff          User?    @relation(fields: [staff_id], references: [id])
  ticket         Ticket   @relation(fields: [ticket_id], references: [id])
}

model RefundRequest {
  id            String    @id @default(uuid())
  ticket_id     String
  customer_id   String
  status        String    @default("pending")
  refund_amount Decimal
  type          String    @default("customer_request")
  reason        String?   @db.Text
  admin_notes   String?   @db.Text
  admin_id      String?
  approved_at   DateTime?
  created_at    DateTime  @default(now())
  customer      User      @relation(fields: [customer_id], references: [id])
  ticket        Ticket    @relation(fields: [ticket_id], references: [id])
}

model EscrowPayout {
  id                  String    @id @default(uuid())
  event_id            String
  total_revenue       Decimal
  net_payout          Decimal
  status              String    @default("pending")
  payout_trans_id     String?
  admin_notes         String?
  bank_info           Json?
  created_at          DateTime  @default(now())
  evidence_url        String?
  platform_fee        Decimal   @default(0)
  processed_at        DateTime?
  requested_at        DateTime?
  updated_at          DateTime  @updatedAt
  commission_fee      Decimal   @default(0)
  gas_fee             Decimal   @default(0)
  marketplace_royalty Decimal   @default(0)
  event               Event     @relation(fields: [event_id], references: [id])
}

model DynamicQRToken {
  id         String   @id @default(uuid())
  ticket_id  String
  token_hash String   @unique
  expires_at DateTime
  is_used    Boolean  @default(false)
  ticket     Ticket   @relation(fields: [ticket_id], references: [id])
}

model AdminActionLog {
  id          String   @id @default(uuid())
  admin_id    String
  action_type String
  target_id   String
  old_value   String?
  new_value   String?
  created_at  DateTime @default(now())
  admin       User     @relation(fields: [admin_id], references: [id])
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  type       String
  title      String
  message    String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  target_id  String?
  blog_id    String?
  blog       Blog?    @relation(fields: [blog_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id])
}

model Merchandise {
  id                     String                 @id @default(uuid())
  organizer_id           String
  event_id               String?
  name                   String
  description            String?
  price                  Decimal
  stock                  Int                    @default(0)
  image_url              String?
  is_active              Boolean                @default(true)
  created_at             DateTime               @default(now())
  updated_at             DateTime               @updatedAt
  commission_fee_percent Decimal?               @default(0)
  platform_fee_percent   Decimal?               @default(0)
  event                  Event?                 @relation(fields: [event_id], references: [id])
  organizer              Organizer              @relation(fields: [organizer_id], references: [id])
  order_items            MerchandiseOrderItem[]
}

model MerchandiseOrderItem {
  id             String                   @id @default(uuid())
  merchandise_id String
  order_id       String
  quantity       Int
  unit_price     Decimal
  subtotal       Decimal
  is_redeemed    Boolean                  @default(false)
  owner_id       String?
  listing_id     String?
  pickup_code    String?                  @unique
  redeemed_at    DateTime?
  commission_fee Decimal?                 @default(0)
  platform_fee   Decimal?                 @default(0)
  listing        MarketplaceListing?      @relation("ListingMerchandise", fields: [listing_id], references: [id])
  merchandise    Merchandise              @relation(fields: [merchandise_id], references: [id])
  order          Order                    @relation(fields: [order_id], references: [id])
  owner          User?                    @relation("ProductOwner", fields: [owner_id], references: [id])
  scan_history   MerchandiseScanHistory[]
}

model Blog {
  id             String         @id @default(uuid())
  author_id      String
  event_id       String?
  title          String
  slug           String         @unique
  content        String
  image_url      String?
  type           String         @default("ORGANIZER_NEWS")
  status         String         @default("published")
  views          Int            @default(0)
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  images         String[]       @default([])
  saved_user_ids String[]       @default([])
  author         User           @relation("BlogAuthor", fields: [author_id], references: [id])
  event          Event?         @relation(fields: [event_id], references: [id])
  reports        BlogReport[]
  comments       Comment[]
  likes          Like[]
  notifications  Notification[]
}

model BlogReport {
  id          String   @id @default(uuid())
  blog_id     String
  reporter_id String
  reason      String
  status      String   @default("pending")
  created_at  DateTime @default(now())
  blog        Blog     @relation(fields: [blog_id], references: [id], onDelete: Cascade)
  reporter    User     @relation(fields: [reporter_id], references: [id])
}

model Comment {
  id            String    @id @default(uuid())
  blog_id       String
  user_id       String
  content       String
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  image_url     String?
  like_user_ids String[]  @default([])
  parent_id     String?
  blog          Blog      @relation(fields: [blog_id], references: [id], onDelete: Cascade)
  parent        Comment?  @relation("CommentToReply", fields: [parent_id], references: [id])
  replies       Comment[] @relation("CommentToReply")
  user          User      @relation(fields: [user_id], references: [id])
}

model Like {
  id         String   @id @default(uuid())
  blog_id    String
  user_id    String
  created_at DateTime @default(now())
  blog       Blog     @relation(fields: [blog_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id])

  @@unique([blog_id, user_id])
}

model WalletTransaction {
  id          String   @id @default(uuid())
  amount      Decimal
  type        String
  description String?
  status      String   @default("completed")
  created_at  DateTime @default(now())
  user_id     String?
  user        User?    @relation(fields: [user_id], references: [id])
}

model WithdrawalRequest {
  id                  String    @id @default(uuid())
  amount              Decimal
  bank_name           String
  account_number      String
  account_holder      String
  status              String    @default("pending")
  admin_notes         String?
  processed_at        DateTime?
  created_at          DateTime  @default(now())
  user_id             String?
  fee_percent         Decimal   @default(0)  // % phí tại thời điểm yêu cầu (snapshot)
  fee_amount          Decimal   @default(0)
  net_amount          Decimal   @default(0)
  payout_trans_id     String?
  bank_transaction_id String?
  evidence_url        String?
  user                User?     @relation(fields: [user_id], references: [id])
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updated_at  DateTime @updatedAt
}

model MerchandiseScanHistory {
  id             String               @id @default(uuid())
  order_item_id  String
  is_success     Boolean
  failure_reason String?
  scanned_at     DateTime             @default(now())
  staff_id       String?
  order_item     MerchandiseOrderItem @relation(fields: [order_item_id], references: [id])
  staff          User?                @relation(fields: [staff_id], references: [id])
}
